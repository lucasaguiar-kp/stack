BETTER_AUTH_SECRET=replace-with-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001
VITE_SERVER_URL=http://localhost:3000
APP_INSTALL_DIR=
APP_GIT_REMOTE_URL=
APP_GIT_BRANCH=main
APP_CURRENT_COMMIT=

# Shared PBX host for local Asterisk/MQTT/WebRTC access
PBX_HOST=127.0.0.1
DEVICE_HTTP_USERNAME=admin
DEVICE_HTTP_PASSWORD=khomp
INTERNAL_SERVER_URL=

# Optional explicit frontend overrides. Leave blank to derive from PBX_HOST.
VITE_ASTERISK_WS_URL=
VITE_ASTERISK_SIP_DOMAIN=
VITE_MQTT_PUBLIC_URL=
VITE_WEBRTC_STUN_URLS=stun:stun.l.google.com:19302

# Local app runtime
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stack-pbx
MQTT_BROKER_HOST=
MQTT_BROKER_PORT=1883
MQTT_PUBLIC_URL=
MQTT_BROKER_USE_TLS=false
# Recomendado definir ambos; no Docker isso habilita autenticacao no EMQX.
MQTT_BROKER_USERNAME=stack-pbx
MQTT_BROKER_PASSWORD=change-me-mqtt

ASTERISK_AUTO_PROVISION=true
ASTERISK_AMI_HOST=
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USERNAME=admin
ASTERISK_AMI_PASSWORD=admin123
ASTERISK_DEVICE_HOST=
ASTERISK_DEVICE_SIP_PORT=5060
ASTERISK_DIALPLAN_CONTEXT_PREFIX=org
ASTERISK_PJSIP_TRANSPORT=transport-udp
ASTERISK_GENERATED_PJSIP_DIR=
ASTERISK_GENERATED_EXTENSIONS_DIR=

# Docker container overrides
DOCKER_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/stack-pbx
DOCKER_INTERNAL_SERVER_URL=http://server:3000
DOCKER_MQTT_BROKER_HOST=emqx
DOCKER_ASTERISK_AMI_HOST=asterisk
DOCKER_ASTERISK_GENERATED_PJSIP_DIR=/app/infra/asterisk/generated/pjsip/devices
DOCKER_ASTERISK_GENERATED_EXTENSIONS_DIR=/app/infra/asterisk/generated/extensions/groups
